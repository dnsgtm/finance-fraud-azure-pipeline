{
	"name": "pl_landing_to_bronze",
	"properties": {
		"activities": [
			{
				"name": "ForEach_Entity",
				"type": "ForEach",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@pipeline().parameters.p_entities",
						"type": "Expression"
					},
					"isSequential": false,
					"batchCount": 5,
					"activities": [
						{
							"name": "CheckFileExists",
							"type": "GetMetadata",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"dataset": {
									"referenceName": "ds_landing_generic",
									"type": "DatasetReference",
									"parameters": {
										"p_folder_path": {
											"value": "@concat(item().landing_folder, '/ingestion_date=', pipeline().parameters.p_ingestion_date, '/')",
											"type": "Expression"
										}
									}
								},
								"fieldList": [
									"exists"
								],
								"storeSettings": {
									"type": "AzureBlobFSReadSettings",
									"enablePartitionDiscovery": false
								},
								"formatSettings": {
									"type": "BinaryReadSettings"
								}
							}
						}
					]
				}
			}
		],
		"parameters": {
			"p_ingestion_date": {
				"type": "string",
				"defaultValue": "2026-07-16"
			},
			"p_entities": {
				"type": "array",
				"defaultValue": [
					{
						"entity": "transactions",
						"landing_folder": "transactions",
						"source_format": "csv"
					},
					{
						"entity": "users",
						"landing_folder": "users",
						"source_format": "csv"
					},
					{
						"entity": "cards",
						"landing_folder": "cards",
						"source_format": "csv"
					},
					{
						"entity": "mcc_codes",
						"landing_folder": "mcc_codes",
						"source_format": "json"
					},
					{
						"entity": "fraud_labels",
						"landing_folder": "fraud_labels",
						"source_format": "json"
					}
				]
			}
		},
		"annotations": []
	}
}